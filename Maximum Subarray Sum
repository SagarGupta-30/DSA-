#include <iostream>
using namespace std;

int maxSubarray(int arr[], int n) {
    int maxSum = arr[0], curr = arr[0];

    for(int i = 1; i < n; i++) {
        curr = max(arr[i], curr + arr[i]);
        maxSum = max(maxSum, curr);
    }
    return maxSum;
}

int main() {
    int arr[] = {-2,1,-3,4,-1,2,1,-5,4};
    int n = 9;

    cout << maxSubarray(arr, n);
}
